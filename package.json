{
  "name": "polymarket-weather-intel",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 1 — data collection for Polymarket daily-temperature resolution intelligence",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "db:generate": "pnpm --filter @weather/db run generate",
    "db:migrate": "pnpm --filter @weather/db run migrate",
    "collect:polymarket": "pnpm --filter @weather/collector-polymarket run start",
    "collect:kalshi": "pnpm --filter @weather/collector-kalshi run start",
    "collect:weather": "pnpm --filter @weather/collector-weather run start",
    "backfill:prices": "pnpm --filter @weather/collector-polymarket run backfill",
    "backfill:kalshi": "pnpm --filter @weather/collector-kalshi run backfill",
    "backfill:weather": "pnpm --filter @weather/collector-weather run backfill",
    "report:phase1": "tsx scripts/phase1-report.ts",
    "report:phase2": "tsx scripts/phase2-reconciliation.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  }
}
