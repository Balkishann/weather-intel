# Copy to .env and fill in. .env is gitignored — never commit secrets.

# ---- Database (PostgreSQL) ----
POSTGRES_USER=weather
POSTGRES_PASSWORD=weather
POSTGRES_DB=weather
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Full URL used by the app/migrations (host=postgres inside docker-compose)
DATABASE_URL=postgresql://weather:weather@localhost:5432/weather

# ---- Cache (Redis) ----
REDIS_URL=redis://localhost:6379

# ---- HTTP / collectors ----
# NWS requires a descriptive User-Agent with contact info (their policy).
NWS_USER_AGENT=polymarket-weather-intel/0.1 (rathodbalkishan284@gmail.com)
LOG_LEVEL=info

# Collection cadence (cron expressions)
CRON_MARKETS=*/10 * * * *
CRON_PRICES=*/2 * * * *
CRON_WEATHER_FORECAST=0 * * * *
CRON_WEATHER_OBS=15 * * * *

# Optional: NOAA Climate Data Online token (free, https://www.ncdc.noaa.gov/cdo-web/token)
# NOAA_CDO_TOKEN=

# ---- Wallet (PHASE 7 ONLY — unused in Phase 1, do not fill yet) ----
# POLYGON_RPC_URL=
# WALLET_PRIVATE_KEY=
